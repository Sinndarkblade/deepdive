<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DeepDive</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg-deep: #020203;
      --bg-base: #050810;
      --bg-elevated: #0a0e1a;
      --bg-surface: #111827;
      --border: rgba(255, 255, 255, 0.06);
      --border-hover: rgba(255, 255, 255, 0.12);
      --text-primary: #ededef;
      --text-secondary: #8a8f98;
      --text-muted: #4a5060;
      --accent: #00ccaa;
      --accent-glow: rgba(0, 204, 170, 0.15);
      --accent-hover: #00e6bf;
      --danger: #e74c3c;
      --warning: #f39c12;
      --success: #2ecc71;
      --radius: 12px;
      --radius-sm: 8px;
      --font: 'Inter', system-ui, -apple-system, sans-serif;
      --font-mono: 'JetBrains Mono', 'Fira Code', monospace;
    }

    body {
      background: var(--bg-deep);
      color: var(--text-primary);
      font-family: var(--font);
      height: 100vh;
      overflow: hidden;
    }

    /* ── LOGIN SCREEN ── */
    #login-screen {
      display: flex;
      align-items: center;
      justify-content: center;
      height: 100vh;
      background: radial-gradient(ellipse at 30% 50%, rgba(0, 204, 170, 0.04) 0%, transparent 60%),
                  radial-gradient(ellipse at 70% 50%, rgba(0, 100, 200, 0.03) 0%, transparent 60%),
                  var(--bg-deep);
    }

    .login-container {
      width: 420px;
      text-align: center;
    }

    .login-logo {
      font-size: 48px;
      margin-bottom: 8px;
    }

    .login-title {
      font-size: 32px;
      font-weight: 700;
      letter-spacing: -0.5px;
      margin-bottom: 4px;
    }

    .login-title span {
      color: var(--accent);
    }

    .login-subtitle {
      font-size: 14px;
      color: var(--text-secondary);
      margin-bottom: 40px;
      line-height: 1.5;
    }

    .login-btn {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 14px 32px;
      background: var(--accent);
      color: var(--bg-deep);
      border: none;
      border-radius: var(--radius);
      font-size: 15px;
      font-weight: 600;
      font-family: var(--font);
      cursor: pointer;
      transition: all 0.2s;
      box-shadow: 0 0 30px rgba(0, 204, 170, 0.2);
    }

    .login-btn:hover {
      background: var(--accent-hover);
      box-shadow: 0 0 40px rgba(0, 204, 170, 0.35);
      transform: translateY(-1px);
    }

    .login-btn:active {
      transform: translateY(0);
    }

    .login-divider {
      display: flex;
      align-items: center;
      margin: 24px 0;
      gap: 12px;
    }

    .login-divider::before, .login-divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    .login-divider span {
      font-size: 11px;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .login-status {
      margin-top: 20px;
      font-size: 12px;
      color: var(--text-muted);
      min-height: 20px;
    }

    .login-status.success { color: var(--success); }
    .login-status.error { color: var(--danger); }

    .login-note {
      margin-top: 32px;
      font-size: 11px;
      color: var(--text-muted);
      line-height: 1.6;
    }

    .login-note a {
      color: var(--accent);
      text-decoration: none;
    }

    .version {
      position: fixed;
      bottom: 16px;
      right: 16px;
      font-size: 10px;
      color: var(--text-muted);
      font-family: var(--font-mono);
    }

    .brand {
      position: fixed;
      bottom: 16px;
      left: 16px;
      font-size: 10px;
      color: var(--text-muted);
    }

    /* ── DASHBOARD (shown after login) ── */
    #dashboard {
      display: none;
      height: 100vh;
    }

    /* ── ANIMATIONS ── */
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .login-container > * {
      animation: fadeIn 0.5s ease-out both;
    }

    .login-container > *:nth-child(2) { animation-delay: 0.1s; }
    .login-container > *:nth-child(3) { animation-delay: 0.2s; }
    .login-container > *:nth-child(4) { animation-delay: 0.3s; }
    .login-container > *:nth-child(5) { animation-delay: 0.4s; }
  </style>
</head>
<body>

  <!-- LOGIN -->
  <div id="login-screen">
    <div class="login-container">
      <div class="login-logo">🔍</div>
      <h1 class="login-title">Deep<span>Dive</span></h1>
      <p class="login-subtitle">
        AI-Powered Research & Discovery<br>
        Map connections. Follow the money. Uncover the truth.
      </p>

      <button class="login-btn" onclick="startLogin()">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
          <polyline points="10 17 15 12 10 7"/>
          <line x1="15" y1="12" x2="3" y2="12"/>
        </svg>
        Sign in with Claude
      </button>

      <div class="login-divider"><span>or</span></div>

      <button class="login-btn" style="background:var(--bg-surface);color:var(--text-primary);box-shadow:none;border:1px solid var(--border)" onclick="importCLI()">
        Import from Claude CLI
      </button>

      <div id="login-status" class="login-status"></div>

      <div class="login-note">
        Requires Claude Pro or Max subscription.<br>
        <a href="https://claude.ai/settings/billing" target="_blank">Manage subscription →</a>
      </div>
    </div>
  </div>

  <!-- DASHBOARD (loads after auth) -->
  <div id="dashboard">
    <iframe id="board-frame" style="width:100%;height:100%;border:none;"></iframe>
  </div>

  <div class="version">v0.1.0</div>
  <div class="brand">Phoenix Quantum Labs LLC</div>

  <script>
    const SERVER = 'http://localhost:8766';

    async function startLogin() {
      const status = document.getElementById('login-status');
      status.textContent = 'Opening browser...';
      status.className = 'login-status';

      try {
        const res = await fetch(SERVER + '/auth/login', { method: 'POST' });
        const data = await res.json();
        if (data.success) {
          status.textContent = 'Logged in as ' + (data.email || 'user');
          status.className = 'login-status success';
          setTimeout(() => showDashboard(), 1000);
        } else {
          status.textContent = data.error || 'Login failed';
          status.className = 'login-status error';
        }
      } catch (e) {
        status.textContent = 'Server not running. Start the DeepDive backend first.';
        status.className = 'login-status error';
      }
    }

    async function importCLI() {
      const status = document.getElementById('login-status');
      status.textContent = 'Importing credentials...';

      try {
        const res = await fetch(SERVER + '/auth/import_cli', { method: 'POST' });
        const data = await res.json();
        if (data.success) {
          status.textContent = 'Imported: ' + (data.email || 'user');
          status.className = 'login-status success';
          setTimeout(() => showDashboard(), 1000);
        } else {
          status.textContent = 'No Claude CLI credentials found. Use Sign in instead.';
          status.className = 'login-status error';
        }
      } catch (e) {
        status.textContent = 'Server not running.';
        status.className = 'login-status error';
      }
    }

    async function checkAuth() {
      try {
        const res = await fetch(SERVER + '/auth/status', { method: 'POST' });
        const data = await res.json();
        if (data.authenticated) {
          showDashboard();
        }
      } catch (e) {
        // Server not running yet, stay on login
      }
    }

    function showDashboard() {
      document.getElementById('login-screen').style.display = 'none';
      document.getElementById('dashboard').style.display = 'block';
      // Load the investigation board into the iframe
      // For now, show a placeholder until we build the dashboard
      document.getElementById('board-frame').srcdoc = `
        <html><body style="background:#050810;color:#00ccaa;font-family:system-ui;display:flex;align-items:center;justify-content:center;height:100vh">
          <div style="text-align:center">
            <h1 style="font-size:24px;margin-bottom:8px">Welcome to DeepDive</h1>
            <p style="color:#8a8f98">Investigation dashboard loading...</p>
          </div>
        </body></html>
      `;
    }

    // Check auth on load
    checkAuth();
  </script>
</body>
</html>
