{
  "$schema": "https://raw.githubusercontent.com/nicedoc/html-component/main/tauri.conf.json.schema",
  "productName": "DeepDive",
  "version": "0.1.0",
  "identifier": "com.phoenixquantumlabs.deepdive",
  "build": {
    "frontendDist": "../../frontend",
    "devUrl": "http://localhost:8766"
  },
  "app": {
    "windows": [
      {
        "title": "DeepDive — OSINT Investigation Platform",
        "url": "http://localhost:8766/board",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self' http://localhost:* ws://localhost:* https://fonts.googleapis.com https://fonts.gstatic.com https://d3js.org https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self' 'unsafe-inline' https://d3js.org https://cdn.jsdelivr.net; img-src 'self' data: https:; connect-src 'self' http://localhost:* ws://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["python3", "python3-pip"]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "externalBin": [],
    "resources": [
      "../../core/**/*",
      "../../server/**/*",
      "../../frontend/**/*",
      "../../cli/**/*",
      "../../requirements.txt"
    ]
  }
}
